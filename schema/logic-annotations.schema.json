{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicchart.dev/schema/logic-annotations.schema.json",
  "title": "LogicChart optional annotation sidecar",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "model_hash"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "model_hash": {
      "type": "string",
      "minLength": 1
    },
    "generated_by": {
      "type": "object",
      "additionalProperties": true
    },
    "flows": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/flow_annotation"
      }
    },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/node_annotation"
      }
    },
    "findings": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/finding_annotation"
      }
    },
    "scopes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scope_annotation"
      }
    }
  },
  "$defs": {
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "flow_annotation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "$ref": "#/$defs/label" },
        "description": { "$ref": "#/$defs/text" },
        "summary": { "$ref": "#/$defs/text" }
      },
      "minProperties": 1
    },
    "node_annotation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "$ref": "#/$defs/label" },
        "description": { "$ref": "#/$defs/text" }
      },
      "minProperties": 1
    },
    "finding_annotation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": { "$ref": "#/$defs/text" },
        "explanation": { "$ref": "#/$defs/text" },
        "remediation": { "$ref": "#/$defs/text" }
      },
      "minProperties": 1
    },
    "scope_annotation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "$ref": "#/$defs/label" },
        "description": { "$ref": "#/$defs/text" },
        "summary": { "$ref": "#/$defs/text" }
      },
      "minProperties": 1
    }
  }
}
